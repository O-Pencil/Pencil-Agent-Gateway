# Dependencies
node_modules/

# Build output
dist/

# Test coverage
coverage/

# Environment files
.env
.env.local
.env.*.local

# Data directory (for user data)
data/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Config overrides (keep default.yaml but ignore local overrides)
config/local.yaml
config/production.yaml

# Deploy: rendered secrets (keep .example templates, ignore real ones)
deploy/.env
deploy/Caddyfile
deploy/gateway.json
deploy/secrets/

# Local pencil instances: each pencils/<name>/ holds a private Gateway
# config + dataDir for one PencilAgent. Templates live under pencils/.example/
# and are version-controlled.
pencils/*
!pencils/.example/
!pencils/README.md

# Channel relays: source is committed, but each relay subproject installs its
# own deps and may emit build artefacts.
relays/*/node_modules/
relays/*/dist/
relays/*/.env
relays/*/.env.local

#extensions
.memory-experiments/
.claude/
.mcp.json
