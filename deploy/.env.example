# Pencil Agent Gateway + Asgard 全栈部署配置
#
# 复制为 .env 后改下面所有 CHANGE_ME 占位符。
# .env 文件**绝不**要提交到 git——根 .gitignore 已经忽略。

# ───────────────────────────────────────────────
# 1. 域名 / TLS
# ───────────────────────────────────────────────
# Caddy 会用这个域名向 Let's Encrypt 申请证书。
# 域名的 A 记录必须指向这台机器的公网 IP，且 80/443 通畅。
DOMAIN=example.com
ACME_EMAIL=ops@example.com

# ───────────────────────────────────────────────
# 2. Postgres（Asgard 业务数据库）
# ───────────────────────────────────────────────
POSTGRES_DB=asgard
POSTGRES_USER=asgard
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# ───────────────────────────────────────────────
# 3. Asgard API
# ───────────────────────────────────────────────
# JWT 签发密钥，至少 32 字节随机串。生成方式：openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_jwt_secret_at_least_32_bytes

# Asgard API 监听端口（容器内），通常不用动
ASGARD_API_PORT=8000

# ───────────────────────────────────────────────
# 4. Pencil Agent Gateway 内部凭据
# ───────────────────────────────────────────────
# Asgard API → Gateway 的服务间共享密钥。
# 这把 key 永远不下发给前端 / editor / 终端用户。
# 生成方式：openssl rand -hex 24
GATEWAY_INTERNAL_KEY=CHANGE_ME_gateway_internal_key

# Gateway 优雅停机超时（毫秒）。容器收到 SIGTERM 后等引擎清理的时间上限。
SHUTDOWN_TIMEOUT_MS=10000

# ───────────────────────────────────────────────
# 5. 模型 Provider 凭据（选其一）
# ───────────────────────────────────────────────
# 方案 A（推荐）：在宿主机本地 nano-pencil 登录后挂载 auth.json
# 命令参考 deploy/README.md §"首次注入凭据"。
#   docker compose cp ./secrets/nanopencil-auth.json gateway:/root/.nanopencil/auth.json
# 不在 .env 里填 ANTHROPIC_API_KEY，直接走 inherited 模式。

# 方案 B：直接传 env 给 Gateway 容器，Agent 配置里用 ${ANTHROPIC_API_KEY} 引用。
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Cloud/hosted preview overrides
# Use this when Asgard API points at an external managed Postgres such as InsForge.
# In Render, set DATABASE_URL directly on the asgard-api service instead of committing it here.
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DB_TABLE_PREFIX=asgard_
SINGLE_USER_MODE=true
ADMIN_EMAIL=admin@asgard.dev
ADMIN_PASSWORD=CHANGE_ME_admin_password
PENCIL_DEFAULT_PROVIDER=openai
PENCIL_DEFAULT_MODEL=gpt-4.1-mini
