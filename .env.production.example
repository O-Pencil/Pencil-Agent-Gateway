# Gateway local-public deploy secrets.
# Copy to .env.production (gitignored) and fill in.
# Loaded by scripts/start-local-public.sh; never committed.

# Bearer token your local client uses in Authorization header.
# Pick any random string — this is the gateway's front-door key.
# Example: openssl rand -hex 24
API_KEY=

# Upstream LLM provider key. With minimax-coding preset this is sk-cp-...
# With dashscope-coding this is sk-sp-...
PROVIDER_API_KEY=
