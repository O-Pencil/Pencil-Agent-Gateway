{
  "name": "pencil-agent-gateway",
  "version": "0.1.0",
  "description": "Runtime gateway for PencilAgent to call Pencil through HTTP or SDK",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:channels": "tsx watch src/channel-server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:channels": "node dist/channel-server.js",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "pencil",
    "agent",
    "gateway",
    "openai-compatible"
  ],
  "author": "Pencil Agent Gateway maintainers",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@pencil-agent/nano-pencil": "^1.13.6",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.16.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.0"
  }
}
